{
  "name": "momentrix-v2",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev --compatibility-date=2024-09-23 --compatibility-flags=nodejs_compat -- next dev",
    "dev:next": "next dev",
    "build": "next build",
    "pages:build": "npx @cloudflare/next-on-pages",
    "preview": "wrangler pages dev .vercel/output/static --compatibility-date=2024-09-23 --compatibility-flags=nodejs_compat",
    "deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static",
    "lint": "next lint",
    "db:create": "wrangler d1 create momentrix-db",
    "db:schema": "wrangler d1 execute momentrix-db --file=supabase/migrations/00001_initial_schema.sql --remote",
    "db:schema:local": "wrangler d1 execute momentrix-db --file=supabase/migrations/00001_initial_schema.sql --local",
    "db:cafe24": "wrangler d1 execute momentrix-db --file=supabase/migrations/00002_cafe24_tokens.sql --remote",
    "db:cafe24:local": "wrangler d1 execute momentrix-db --file=supabase/migrations/00002_cafe24_tokens.sql --local",
    "db:pantos": "wrangler d1 execute momentrix-db --file=supabase/migrations/00003_pantos_columns.sql --remote",
    "db:pantos:local": "wrangler d1 execute momentrix-db --file=supabase/migrations/00003_pantos_columns.sql --local",
    "migrate": "npx tsx scripts/migrate-data.ts"
  },
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "chart.js": "^4.5.1",
    "jose": "^6.2.2",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.2",
    "wrangler": "^4.77.0"
  }
}
